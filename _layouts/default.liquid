<!doctype html>
<html lang="{{ site.lang }}">
  <head>
    {% include head.liquid %}
  </head>
  <body class="flex flex-col md:flex-row min-h-screen w-full bg-white dark:bg-gray-900">
    
    <aside class="w-full md:w-64 lg:w-72 bg-[#1a1a1a] text-white p-8 md:sticky md:top-0 md:h-screen overflow-y-auto">
      {% include header.liquid %}
    </aside>

    <main class="w-full flex-1 p-6 md:p-12 mx-auto max-w-5xl" role="main">
      {{ content }}
    </main>

    {% include scripts.liquid %}
  </body>
</html>